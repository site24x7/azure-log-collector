{
  "scriptFile": "__init__.py",
  "bindings": [
    {
      "type": "httpTrigger",
      "name": "req",
      "direction": "in",
      "methods": ["post"],
      "route": "scan",
      "authLevel": "function"
    },
    {
      "type": "http",
      "name": "$return",
      "direction": "out"
    },
    {
      "type": "queue",
      "name": "scanQueue",
      "direction": "out",
      "queueName": "scan-requests",
      "connection": "AzureWebJobsStorage"
    }
  ]
}
