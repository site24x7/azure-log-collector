# ============================================================
# Azure Diagnostic Logs Collection — Configuration
# ============================================================
# SETUP:
#   1. Copy this file:  cp config.env.example config.env
#   2. Fill in the values below
#   3. Run:  bash setup.sh
#
# To find your subscription IDs, run:
#   az account list --query '[].{Name:name, ID:id}' -o table
# ============================================================

# Required ────────────────────────────────────────────────────

# Comma-separated Azure subscription IDs to monitor
# Example: "aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee"
# Multiple: "sub-id-1,sub-id-2"
SUBSCRIPTION_IDS="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Site24x7 API token for AppLogs integration
# Leave as-is for testing (stub mode — no real Site24x7 calls)
SITE24X7_API_TOKEN="your-token-here"

# Site24x7 data center domain — determines where logs are sent.
# US: site24x7.com | IN: site24x7.in | EU: site24x7.eu
# AU: site24x7.net.au | CN: site24x7.cn | JP: site24x7.jp
SITE24X7_DOMAIN="site24x7.com"

# Optional (defaults shown) ───────────────────────────────────

# Resource group name (will be created if it doesn't exist)
RESOURCE_GROUP_NAME="s247-diag-logs-rg"

# Function App name — MUST be globally unique across all of Azure!
# Leave blank to auto-generate a unique name from your subscription ID.
# Example: "s247-diag-func-myteam"
FUNCTION_APP_NAME=""

# Storage account name — MUST be globally unique, lowercase, no hyphens, 3-24 chars
# Leave blank to auto-generate a unique name from your subscription ID.
# Example: "s247diagmyteam"
STORAGE_ACCOUNT_NAME=""

# Azure region for the Function App and Storage Account
# (Event Hubs are auto-created in each region where resources exist)
FUNCTION_APP_REGION="eastus"

# How often to scan for new resources (Azure Functions CRON format)
# Default: every 6 hours
TIMER_SCHEDULE="0 0 */6 * * *"

# Enable the general catch-all log type for unsupported categories
GENERAL_LOGTYPE_ENABLED="true"

# Auto-update URL — point this to a hosted version.json for automatic updates.
# When configured, the Function App checks daily at 3 AM UTC for new versions
# and deploys them automatically. Leave blank to disable auto-updates.
#
# The version.json format:
# {
#   "version": "1.1.0",
#   "package_url": "https://example.com/function-app-v1.1.0.zip",
#   "release_notes": "Description of changes"
# }
UPDATE_CHECK_URL=""
